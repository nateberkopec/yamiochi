digraph YamiochiFactory {
    graph [
        goal="Select, implement, validate, and merge the next Yamiochi improvement while advancing the current gate frontier"
    ]
    rankdir=LR

    start            [shape=Mdiamond, label="Start"]
    exit             [shape=Msquare, label="Exit"]
    select_work      [label="Select Gate Work / Promotion / Fallback Issue", shape=component]
    fetch_work_item  [label="Fetch Work Item", shape=parallelogram]
    plan             [label="Plan"]
    implement        [label="Implement"]
    validate         [label="Lint + Unit + Scenarios + Bench", shape=parallelogram]
    deny_paths       [label="Denied Paths", shape=parallelogram]
    judge            [label="Judge Review"]
    evaluate_gates   [label="Evaluate Gates", shape=diamond]
    open_pr          [label="Push Branch + Open PR", shape=parallelogram]
    watch_ci         [label="Watch CI", shape=diamond]
    repair           [label="Repair PR"]
    merge            [label="Merge PR", shape=parallelogram]
    promote_baseline [label="Promote Baselines / Update Gate State", shape=parallelogram]

    start -> select_work -> fetch_work_item -> plan -> implement -> validate -> deny_paths -> judge -> evaluate_gates
    evaluate_gates -> open_pr   [label="Blocking gates pass"]
    evaluate_gates -> implement [label="Revise"]
    open_pr -> watch_ci
    watch_ci -> merge  [label="Green"]
    watch_ci -> repair [label="Red"]
    repair -> validate
    merge -> promote_baseline -> select_work
    select_work -> exit [label="No work"]
}
