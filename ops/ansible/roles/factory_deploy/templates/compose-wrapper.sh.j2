#!/usr/bin/env bash
set -euo pipefail

ROOT="{{ factory_root }}"
PROJECT="{{ factory_compose_project_name }}"
RUNTIME_ENV="$ROOT/.env.runtime"
cd "$ROOT"

if docker compose version >/dev/null 2>&1; then
  compose_cmd=(docker compose)
else
  compose_cmd=(docker-compose)
fi

case "${1:-up}" in
  up)
    exec "${compose_cmd[@]}" --project-name "$PROJECT" --env-file "$RUNTIME_ENV" up -d --remove-orphans
    ;;
  down)
    exec "${compose_cmd[@]}" --project-name "$PROJECT" --env-file "$RUNTIME_ENV" down
    ;;
  restart)
    "${compose_cmd[@]}" --project-name "$PROJECT" --env-file "$RUNTIME_ENV" up -d --remove-orphans
    ;;
  pull)
    exec "${compose_cmd[@]}" --project-name "$PROJECT" --env-file "$RUNTIME_ENV" pull
    ;;
  *)
    echo "usage: $0 {up|down|restart|pull}" >&2
    exit 1
    ;;
esac
