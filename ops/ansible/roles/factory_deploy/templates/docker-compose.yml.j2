version: "3.9"

services:
  factory-autopilot:
    image: {{ factory_sandbox_image }}
    restart: unless-stopped
    env_file:
      - {{ factory_root }}/.env.server
    environment:
      FABRO_SERVER: http://127.0.0.1:{{ factory_fabro.listen_port }}
      GITHUB_TOKEN: ${GITHUB_TOKEN}
      GH_TOKEN: ${GITHUB_TOKEN}
      GITHUB_REPOSITORY: {{ factory_repo_url | regex_replace('^https://github.com/', '') | regex_replace('\\.git$', '') }}
      YAMIOCHI_FACTORY_REPOSITORY: {{ factory_repo_url | regex_replace('^https://github.com/', '') | regex_replace('\\.git$', '') }}
      YAMIOCHI_FACTORY_BASELINE_FILE: {{ factory_state_root }}/baselines/merge-gates.json
      YAMIOCHI_FACTORY_WORKTREE_ROOT: {{ factory_state_root }}/worktrees
    command:
      - bash
      - -lc
      - |
        cd {{ factory_repo_checkout_path }}
        while true; do
          ruby factory/scripts/autopilot.rb --once || true
          sleep 30
        done
    volumes:
      - {{ factory_state_root }}:{{ factory_state_root }}
      - {{ factory_state_root }}/fabro-home-remote:/root/.fabro
    network_mode: host
    cpus: 1.0
    mem_limit: 2g

  github-runner-fast:
    image: {{ factory_github_runner_image }}
    restart: unless-stopped
    environment:
      REPO_URL: ${GITHUB_RUNNER_REPO_URL}
      ACCESS_TOKEN: ${GITHUB_RUNNER_ACCESS_TOKEN}
      RUNNER_NAME: yamiochi-factory-fast
      RUNNER_SCOPE: repo
      RUN_AS_ROOT: "true"
      LABELS: self-hosted,linux,x64,factory-fast
      DISABLE_AUTO_UPDATE: "1"
      EPHEMERAL: "1"
      RUNNER_WORKDIR: /tmp/github-runner
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - github-runner-fast-data:/tmp/github-runner
    network_mode: host
    cpus: {{ factory_resources.github_runner_fast.cpus | to_json }}
    mem_limit: {{ factory_resources.github_runner_fast.mem_limit }}

  github-runner-heavy:
    image: {{ factory_github_runner_image }}
    restart: unless-stopped
    environment:
      REPO_URL: ${GITHUB_RUNNER_REPO_URL}
      ACCESS_TOKEN: ${GITHUB_RUNNER_ACCESS_TOKEN}
      RUNNER_NAME: yamiochi-factory-heavy
      RUNNER_SCOPE: repo
      RUN_AS_ROOT: "true"
      LABELS: self-hosted,linux,x64,factory-heavy
      DISABLE_AUTO_UPDATE: "1"
      EPHEMERAL: "1"
      RUNNER_WORKDIR: /tmp/github-runner
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - github-runner-heavy-data:/tmp/github-runner
    network_mode: host
    cpus: {{ factory_resources.github_runner_heavy.cpus | to_json }}
    mem_limit: {{ factory_resources.github_runner_heavy.mem_limit }}

volumes:
  github-runner-fast-data:
  github-runner-heavy-data:
