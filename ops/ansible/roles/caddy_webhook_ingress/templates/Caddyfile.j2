{{ factory_public_ingress.domain }} {
  @github_webhook {
    path {{ factory_public_ingress.webhook_path }}
    method POST
  }

  handle @github_webhook {
    reverse_proxy 127.0.0.1:{{ factory_fabro.listen_port }}
  }

  respond 404
}

{{ factory_private_ui_domain }} {
  tls /etc/caddy/private-ui/fabro-ui.crt /etc/caddy/private-ui/fabro-ui.key
  encode zstd gzip

  reverse_proxy 127.0.0.1:{{ factory_fabro.listen_port }}
}
